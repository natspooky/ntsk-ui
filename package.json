{
	"name": "@natski/ntsk-ui",
	"version": "0.1.0",
	"description": "A component library for the ntsk-ui library",
	"keywords": [
		"ntsk"
	],
	"module": "./dist/ntsk-ui.esm.js",
	"main": "./dist/ntsk-ui.cjs.js",
	"exports": {
		"import": "./dist/ntsk-ui.esm.js",
		"require": "./dist/ntsk-ui.cjs.js"
	},
	"unpkg": "./dist/ntsk-ui.min.js",
	"jsdelivr": "./dist/ntsk-ui.min.js",
	"homepage": "https://natski.dev/packages/ntsk-ui",
	"scripts": {
		"build": "rollup -c",
		"test": "echo \"Error: no test specified yet\"",
		"prepare": "husky install && npm run build",
		"lint": "eslint --fix",
		"dev": "nodemon --exec \"npm run build\""
	},
	"nodemonConfig": {
		"ignore": [
			"**/dist/**"
		],
		"delay": 500
	},
	"husky": {
		"hooks": {
			"pre-commit": "lint-staged"
		}
	},
	"lint-staged": {
		"*.{js,json,md}": [
			"prettier --write",
			"eslint --fix"
		]
	},
	"author": "Natski",
	"license": "MIT",
	"type": "module",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/natspooky/ntsk-ui.git"
	},
	"files": [
		"dist"
	],
	"include": [
		"dist"
	],
	"exclude": [
		"node_modules",
		"src",
		"test",
		".husky",
		".github"
	],
	"devDependencies": {
		"@eslint/js": "^9.39.4",
		"@rollup/plugin-terser": "^1.0.0",
		"eslint": "^9.39.4",
		"eslint-config-prettier": "^10.1.8",
		"eslint-plugin-prettier": "^5.5.5",
		"globals": "^17.6.0",
		"husky": "^8.0.0",
		"lint-staged": "^16.4.0",
		"nodemon": "^3.1.14",
		"prettier": "^3.8.3",
		"rollup": "^2.80.0"
	}
}
